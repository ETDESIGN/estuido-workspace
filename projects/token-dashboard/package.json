{
  "name": "token-dashboard",
  "version": "1.0.0",
  "description": "Token Tracking Dashboard for ESTUDIO - Parse OpenClaw session logs and track API costs",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
