{
  "name": "discord-commands",
  "description": "Custom Discord slash commands for session management",
  "version": "1.0.0",
  "enabled": true,
  "commands": {
    "new": {
      "handler": "./new.js",
      "description": "Create a new session",
      "userInvocable": true
    },
    "model-kimi": {
      "handler": "./model-kimi.js",
      "description": "Switch to Kimi K2.5 (OpenRouter)",
      "userInvocable": true
    },
    "model-minimax": {
      "handler": "./model-minimax.js",
      "description": "Switch to MiniMax M2.5 (OpenRouter)",
      "userInvocable": true
    },
    "model-glm47": {
      "handler": "./model-glm47.js",
      "description": "Switch to GLM 4.7",
      "userInvocable": true
    },
    "flush-context": {
      "handler": "./flush-context.js",
      "description": "Flush context window",
      "userInvocable": true
    }
  }
}
